APP_NAME=TaskFlow AI Agent
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME=deah
GCS_PREFIX=requirements-pod
GCS_PROJECT_ID=verizon-data
# Local dev: set to your key file path. On GCP VM: leave empty — VM SA is used automatically.
GCS_CREDENTIALS_PATH=./core/requirements_pod/credentials/gcs-sa-key.json
LOCAL_STORAGE_PATH=./local_storage
# LLM_PROVIDER options: claude-sdk | claude | mock
# claude-sdk: uses Claude Code CLI OAuth — no ANTHROPIC_API_KEY required
# claude:     uses Anthropic API directly — requires ANTHROPIC_API_KEY in .env
# mock:       returns fixture data for local testing
LLM_PROVIDER=claude-code-sdk
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=8192
LLM_CHUNK_SIZE=3000
LLM_CHUNK_OVERLAP=200
JIRA_BASE_URL=https://prodapt-deah.atlassian.net
JIRA_EMAIL=pavithra.k@prodapt.com
JIRA_API_KEY=REPLACE_ME
JIRA_PROJECT_KEY=SCRUM
JIRA_ISSUE_TYPE_MAP={"bug":"Bug","story":"Story","task":"Task","subtask":"Sub-task"}
CORS_ORIGINS=*
PROJECT_CONTEXT_FILE=./core/requirements_pod/project_context.md
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,md,vtt,srt
