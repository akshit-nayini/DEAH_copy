%% Architecture Flow: Customer 360 | GCP | batch
flowchart LR

    subgraph rec["⭐ Option 1: Cloud Composer + Dataflow Batch Pipeline — Recommended"]
        direction LR
        I1["📥 Ingestion<br/>Dataflow"]
        P1["⚙️ Processing<br/>Dataflow"]
        S1["💾 Storage<br/>BigQuery + GCS"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Composer"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring + Logging"]
        IaC1["🔨 IaC<br/>Terraform"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o2["Option 2: Cloud Functions + Dataproc Batch Processing"]
        direction LR
        I2["📥 Ingestion<br/>Cloud Functions + Dataproc"]
        P2["⚙️ Processing<br/>Dataproc"]
        S2["💾 Storage<br/>BigQuery + GCS"]
        C2["📊 Consumption<br/>Consumption"]
        I2 --> P2 --> S2 --> C2
    end

    subgraph o3["Option 3: Minimal Cloud Run + BigQuery Data Transfer"]
        direction LR
        I3["📥 Ingestion<br/>Cloud Run"]
        P3["⚙️ Processing<br/>BigQuery"]
        S3["💾 Storage<br/>BigQuery + GCS"]
        C3["📊 Consumption<br/>Consumption"]
        I3 --> P3 --> S3 --> C3
    end

    classDef recommended fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef rejected fill:#f8f9fa,stroke:#6c757d,stroke-width:1px,stroke-dasharray:4
    class I1,P1,S1,C1,Orch1,Mon1,IaC1 recommended
    class I2,P2,S2,C2,I3,P3,S3,C3 rejected
