%% Architecture Flow: Customer360 | GCP | batch
flowchart TB

    subgraph rec["⭐ Option 1: Cloud Composer + Dataflow (Apache Beam) + BigQuery — Recommended"]
        I1["📥 Ingestion<br/>Google Cloud Dataflow (JDBC MySQL Source Connector)"]
        P1["⚙️ Processing<br/>Google Cloud Dataflow (Apache Beam SDK)"]
        S1["💾 Storage<br/>Google Cloud Storage + BigQuery"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Composer 2 (Apache Airflow)"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring + Cloud Logging + Dataflow Job Metrics"]
        IaC1["🔨 IaC<br/>Terraform (hashicorp/google provider)"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o2["Option 2: Cloud Composer + Dataproc (PySpark) + BigQuery"]
        I2["📥 Ingestion<br/>Dataproc Ephemeral Cluster (Spark JDBC MySQL Connector)"]
        P2["⚙️ Processing<br/>Google Cloud Dataproc (PySpark)"]
        S2["💾 Storage<br/>Google Cloud Storage + BigQuery"]
        C2["📊 Consumption<br/>Consumption"]
        I2 --> P2 --> S2 --> C2
    end

    subgraph o3["Option 3: Cloud Composer + Cloud Data Fusion + BigQuery"]
        I3["📥 Ingestion<br/>Cloud Data Fusion (MySQL JDBC Source Plugin)"]
        P3["⚙️ Processing<br/>Cloud Data Fusion (managed Dataflow backend)"]
        S3["💾 Storage<br/>Google Cloud Storage + BigQuery"]
        C3["📊 Consumption<br/>Consumption"]
        I3 --> P3 --> S3 --> C3
    end

    rec ~~~ o2
    o2 ~~~ o3

    classDef recommended fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef rejected fill:#f8f9fa,stroke:#6c757d,stroke-width:1px,stroke-dasharray:4
    class I1,P1,S1,C1,Orch1,Mon1,IaC1 recommended
    class I2,P2,S2,C2,I3,P3,S3,C3 rejected
