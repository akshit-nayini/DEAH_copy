%% Architecture Flow: Customer360 | GCP | batch
flowchart LR

    subgraph rec["⭐ Option 2: Cloud Functions + Cloud Scheduler + BigQuery — Recommended"]
        direction LR
        I1["📥 Ingestion<br/>Cloud Functions"]
        P1["⚙️ Processing<br/>Cloud Functions"]
        S1["💾 Storage<br/>BigQuery"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Scheduler"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring"]
        IaC1["🔨 IaC<br/>Terraform"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o1["Option 1: Cloud Composer + Cloud SQL Proxy + BigQuery"]
        direction LR
        I1["📥 Ingestion<br/>Cloud SQL Proxy"]
        P1["⚙️ Processing<br/>Dataflow"]
        S1["💾 Storage<br/>BigQuery"]
        C1["📊 Consumption<br/>Consumption"]
        I1 --> P1 --> S1 --> C1
    end

    subgraph o3["Option 3: Datastream + Dataflow + BigQuery"]
        direction LR
        I3["📥 Ingestion<br/>Datastream"]
        P3["⚙️ Processing<br/>Dataflow"]
        S3["💾 Storage<br/>BigQuery"]
        C3["📊 Consumption<br/>Consumption"]
        I3 --> P3 --> S3 --> C3
    end

    classDef recommended fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef rejected fill:#f8f9fa,stroke:#6c757d,stroke-width:1px,stroke-dasharray:4
    class I1,P1,S1,C1,Orch1,Mon1,IaC1 recommended
    class I1,P1,S1,C1,I3,P3,S3,C3 rejected
