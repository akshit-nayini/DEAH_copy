%% Architecture Flow: Customer 360 | GCP | batch
flowchart LR

    subgraph rec["⭐ Option 3: Cloud Functions + GCS + BigQuery Load Jobs — Recommended"]
        direction LR
        I1["📥 Ingestion<br/>Cloud Functions"]
        P1["⚙️ Processing<br/>Cloud Functions"]
        S1["💾 Storage<br/>BigQuery + GCS"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Composer"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring"]
        IaC1["🔨 IaC<br/>Terraform"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o1["Option 1: Cloud SQL Connector + Dataflow + BigQuery"]
        direction LR
        I1["📥 Ingestion<br/>Cloud SQL Connector"]
        P1["⚙️ Processing<br/>Dataflow"]
        S1["💾 Storage<br/>BigQuery"]
        C1["📊 Consumption<br/>Consumption"]
        I1 --> P1 --> S1 --> C1
    end

    subgraph o2["Option 2: Dataproc + BigQuery Direct Load"]
        direction LR
        I2["📥 Ingestion<br/>Dataproc"]
        P2["⚙️ Processing<br/>Dataproc Spark"]
        S2["💾 Storage<br/>BigQuery"]
        C2["📊 Consumption<br/>Consumption"]
        I2 --> P2 --> S2 --> C2
    end

    classDef recommended fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef rejected fill:#f8f9fa,stroke:#6c757d,stroke-width:1px,stroke-dasharray:4
    class I1,P1,S1,C1,Orch1,Mon1,IaC1 recommended
    class I1,P1,S1,C1,I2,P2,S2,C2 rejected
