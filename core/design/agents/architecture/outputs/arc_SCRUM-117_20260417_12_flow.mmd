%% Architecture Flow: Clickstream Analytics Platform | GCP | streaming
flowchart LR

    subgraph rec["⭐ Option 1: Dataflow Direct KafkaIO Streaming — Recommended"]
        direction LR
        I1["📥 Ingestion<br/>Confluent Kafka + Apache Beam KafkaIO"]
        P1["⚙️ Processing<br/>Google Cloud Dataflow (Apache Beam 2.x Streaming Engine)"]
        S1["💾 Storage<br/>Google BigQuery (Storage Write API — exactly-once)"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Composer 2 (Apache Airflow 2.x)"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring + Cloud Logging + Dataflow Native Metrics"]
        IaC1["🔨 IaC<br/>Terraform"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o2["Option 2: Kafka to Pub/Sub Bridge then Dataflow to BigQuery"]
        direction LR
        I2["📥 Ingestion<br/>Confluent Kafka + Cloud Pub/Sub (Kafka-to-Pub/Sub Dataflow Bridge)"]
        P2["⚙️ Processing<br/>Google Cloud Dataflow (Apache Beam 2.x)"]
        S2["💾 Storage<br/>Google BigQuery (Storage Write API)"]
        C2["📊 Consumption<br/>Consumption"]
        I2 --> P2 --> S2 --> C2
    end

    subgraph o3["Option 3: Confluent Cloud ksqlDB with BigQuery Sink Connector"]
        direction LR
        I3["📥 Ingestion<br/>Confluent Kafka (native topics)"]
        P3["⚙️ Processing<br/>Confluent Cloud ksqlDB"]
        S3["💾 Storage<br/>Google BigQuery via Confluent BigQuery Sink Connector (Kafka Connect)"]
        C3["📊 Consumption<br/>Consumption"]
        I3 --> P3 --> S3 --> C3
    end

    classDef recommended fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef rejected fill:#f8f9fa,stroke:#6c757d,stroke-width:1px,stroke-dasharray:4
    class I1,P1,S1,C1,Orch1,Mon1,IaC1 recommended
    class I2,P2,S2,C2,I3,P3,S3,C3 rejected
