%% Architecture Flow: Order Analytics Platform | GCP | hybrid
flowchart LR

    subgraph rec["⭐ Option 1: Full Dataflow Lambda — Unified Apache Beam SDK for Streaming and Batch — Recommended"]
        direction LR
        I1["📥 Ingestion<br/>Google Pub/Sub"]
        P1["⚙️ Processing<br/>Google Dataflow (Apache Beam SDK)"]
        S1["💾 Storage<br/>BigQuery + GCS"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Composer 2"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring + Cloud Logging"]
        IaC1["🔨 IaC<br/>Terraform"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o2["Option 2: Dataflow Streaming + Dataproc Spark Batch — Dual-Framework Lambda"]
        direction LR
        I2["📥 Ingestion<br/>Google Pub/Sub + Dataproc Spark JDBC Connector"]
        P2["⚙️ Processing<br/>Google Dataflow (streaming) + Google Dataproc Spark (batch)"]
        S2["💾 Storage<br/>BigQuery + GCS"]
        C2["📊 Consumption<br/>Consumption"]
        I2 --> P2 --> S2 --> C2
    end

    subgraph o3["Option 3: Dataflow Streaming + Datastream CDC Reconciliation — Continuous Change-Capture Lambda"]
        direction LR
        I3["📥 Ingestion<br/>Google Pub/Sub + Datastream (PostgreSQL Logical Replication CDC)"]
        P3["⚙️ Processing<br/>Google Dataflow (streaming) + BigQuery MERGE via Cloud Composer (batch reconciliation)"]
        S3["💾 Storage<br/>BigQuery + GCS"]
        C3["📊 Consumption<br/>Consumption"]
        I3 --> P3 --> S3 --> C3
    end

    classDef recommended fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef rejected fill:#f8f9fa,stroke:#6c757d,stroke-width:1px,stroke-dasharray:4
    class I1,P1,S1,C1,Orch1,Mon1,IaC1 recommended
    class I2,P2,S2,C2,I3,P3,S3,C3 rejected
