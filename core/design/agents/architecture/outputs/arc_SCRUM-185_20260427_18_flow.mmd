        S3["💾 Storage<br/>BigQuery (staging dataset for CDC events + production dataset for analytics) + GCS (optional Datastream intermediary for replay)"]
        C3["📊 Consumption<br/>Consumption"]
        I3 --> P3 --> S3 --> C3
    end

