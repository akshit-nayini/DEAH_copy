%% Architecture Flow: MySQL to BigQuery Data Ingestion Pipeline | GCP | batch
flowchart TB

    subgraph rec["⭐ Option 3: GCP Datastream (CDC Backfill + Incremental) + Cloud Composer Validation Gate + BigQuery — Recommended"]
        I1["📥 Ingestion<br/>GCP Datastream (MySQL CDC with backfill, GCS destination)"]
        P1["⚙️ Processing<br/>BigQuery (MERGE SQL for dedup and upsert, schema check SQL via INFORMATION_SCHEMA) + Cloud Composer Airflow operators"]
        S1["💾 Storage<br/>BigQuery (target employees table + audit_log + schema_registry) + GCS (Datastream landing zone, Avro change event files)"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Composer 2 (managed Apache Airflow)"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring + Cloud Logging + Looker Studio (BigQuery audit_log dashboard)"]
        IaC1["🔨 IaC<br/>Terraform (GCP provider)"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o1["Option 1: Cloud Composer + Apache Beam/Dataflow JDBC Batch ETL"]
        I1["📥 Ingestion<br/>GCP Dataflow with Apache Beam JDBC IO Connector"]
        P1["⚙️ Processing<br/>Apache Beam SDK (Python or Java) on Dataflow Runner"]
        S1["💾 Storage<br/>BigQuery (target + audit_log) + GCS (state, quarantine, schema snapshots)"]
        C1["📊 Consumption<br/>Consumption"]
        I1 --> P1 --> S1 --> C1
    end

    subgraph o2["Option 2: Cloud Composer + Cloud Run Jobs (Python Micro-Batch ETL)"]
        I2["📥 Ingestion<br/>Cloud Run Jobs (Python, Cloud SQL Python Connector + SQLAlchemy)"]
        P2["⚙️ Processing<br/>Python ETL script (google-cloud-bigquery SDK, pandas optional) within Cloud Run Job container"]
        S2["💾 Storage<br/>BigQuery (target + audit_log + metadata control table) + GCS (state, quarantine, schema snapshots)"]
        C2["📊 Consumption<br/>Consumption"]
        I2 --> P2 --> S2 --> C2
    end

