%% Architecture Flow: MySQL to BigQuery Data Ingestion Pipeline | GCP | batch
flowchart LR

    subgraph rec["⭐ Option 2: Cloud Composer + Cloud Run Jobs (Lightweight Python ETL) — Recommended"]
        direction LR
        I1["📥 Ingestion<br/>Cloud Run Jobs + Cloud SQL Auth Proxy (SQLAlchemy)"]
        P1["⚙️ Processing<br/>Cloud Run Jobs (Python 3.11, pandas, google-cloud-bigquery SDK)"]
        S1["💾 Storage<br/>BigQuery + GCS"]
        C1["📊 Consumption<br/>Consumption"]
        Orch1["📅 Orchestration<br/>Cloud Composer 2 (Apache Airflow 2.x)"]
        Mon1["📋 Monitoring<br/>Cloud Monitoring + Cloud Logging + Looker Studio"]
        IaC1["🔨 IaC<br/>Terraform (google provider)"]
        I1 --> P1 --> S1 --> C1
        Orch1 -.->|schedules| I1
        Orch1 -.->|orchestrates| P1
        Mon1 -.->|observes| P1
        IaC1 -.->|provisions| Orch1
    end

    subgraph o1["Option 1: Cloud Composer + Dataflow (Apache Beam ETL)"]
        direction LR
        I1["📥 Ingestion<br/>Cloud Dataflow (JDBC Source I/O + Cloud SQL Auth Proxy)"]
        P1["⚙️ Processing<br/>Cloud Dataflow (Apache Beam 2.x)"]
        S1["💾 Storage<br/>BigQuery + GCS"]
        C1["📊 Consumption<br/>Consumption"]
        I1 --> P1 --> S1 --> C1
    end

    subgraph o3["Option 3: GCP Datastream (CDC) + BigQuery Direct + Cloud Composer (Validation Gating)"]
        direction LR
        I3["📥 Ingestion<br/>GCP Datastream (MySQL CDC via binlog, private connectivity)"]
        P3["⚙️ Processing<br/>BigQuery (native Datastream destination with auto-MERGE)"]
        S3["💾 Storage<br/>BigQuery + GCS"]
        C3["📊 Consumption<br/>Consumption"]
        I3 --> P3 --> S3 --> C3
    end

    classDef recommended fill:#d4edda,stroke:#28a745,stroke-width:2px
    classDef rejected fill:#f8f9fa,stroke:#6c757d,stroke-width:1px,stroke-dasharray:4
    class I1,P1,S1,C1,Orch1,Mon1,IaC1 recommended
    class I1,P1,S1,C1,I3,P3,S3,C3 rejected
