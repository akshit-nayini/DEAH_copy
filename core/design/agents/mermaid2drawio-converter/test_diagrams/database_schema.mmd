erDiagram
    CUSTOMER {
        int id PK "Primary key"
        string name
        string email
        date created_at
    }
    ORDER {
        int id PK
        int customer_id FK
        float total
        date order_date
        string status
    }
    PRODUCT {
        int id PK
        string name
        float price
        string category
        int stock_qty
    }
    ORDER_ITEM {
        int id PK
        int order_id FK
        int product_id FK
        int quantity
        float unit_price
    }
    PAYMENT {
        int id PK
        int order_id FK
        string method
        float amount
        date paid_at
    }
    CUSTOMER ||--o{ ORDER : places
    ORDER ||--|{ ORDER_ITEM : contains
    PRODUCT ||--o{ ORDER_ITEM : "is in"
    ORDER ||--o{ PAYMENT : "paid via"
